---
import SectionHeader from './SectionHeader.astro';
import Icon from './Icon.astro';

const pins = [
  { x: 22, y: 35, label: 'Veylhold', kind: 'Capital' },
  { x: 58, y: 22, label: 'Skyfracture', kind: 'Storm Rift' },
  { x: 71, y: 60, label: 'The Cinderveil', kind: 'Dragon Roost' },
  { x: 38, y: 70, label: 'Ashmere', kind: 'Ruin' },
];
---
<section id="maps" class="relative py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <SectionHeader
      eyebrow="Cartography"
      title="Maps that remember every mark."
      align="center"
      description="Overlay factions, plot lore hotspots, and watch territory shift across the ages. Built for cartographers who think in centuries."
    />

    <div class="card relative p-2 md:p-3 overflow-hidden">
      <!-- map canvas -->
      <div class="relative aspect-[16/9] rounded-lg overflow-hidden border border-storm/30">
        <!-- parchment + ink layer -->
        <div class="absolute inset-0" style="background:
          radial-gradient(ellipse at 30% 40%, rgba(67,199,199,0.10) 0%, transparent 60%),
          radial-gradient(ellipse at 70% 70%, rgba(184,138,59,0.10) 0%, transparent 55%),
          linear-gradient(135deg, #0c2030 0%, #0a1a26 100%);"></div>

        <!-- grid -->
        <svg class="absolute inset-0 w-full h-full opacity-30" viewBox="0 0 100 56" preserveAspectRatio="none">
          <g stroke="#43C7C7" stroke-opacity="0.18" stroke-width="0.15">
            {Array.from({ length: 11 }).map((_, i) => (
              <line x1={i * 10} y1="0" x2={i * 10} y2="56" />
            ))}
            {Array.from({ length: 7 }).map((_, i) => (
              <line x1="0" y1={i * 8} x2="100" y2={i * 8} />
            ))}
          </g>
        </svg>

        <!-- land masses (stylized) -->
        <svg class="absolute inset-0 w-full h-full" viewBox="0 0 100 56" preserveAspectRatio="none" aria-hidden="true">
          <defs>
            <linearGradient id="land" x1="0" x2="0" y1="0" y2="1">
              <stop offset="0%" stop-color="#173145"/>
              <stop offset="100%" stop-color="#0b1c29"/>
            </linearGradient>
            <linearGradient id="landEdge" x1="0" x2="1" y1="0" y2="0">
              <stop offset="0%" stop-color="#43C7C7" stop-opacity="0.5"/>
              <stop offset="100%" stop-color="#1E7C86" stop-opacity="0.05"/>
            </linearGradient>
          </defs>
          <path d="M5 20 Q15 8 28 14 T55 18 Q65 12 78 18 Q92 24 88 36 Q80 48 60 46 Q40 50 22 44 Q8 38 5 28 Z" fill="url(#land)" stroke="url(#landEdge)" stroke-width="0.3"/>
          <path d="M62 40 Q72 38 82 44 Q84 50 76 52 Q66 52 60 48 Z" fill="url(#land)" stroke="url(#landEdge)" stroke-width="0.3"/>
        </svg>

        <!-- pins -->
        {pins.map((p) => (
          <div
            class="absolute -translate-x-1/2 -translate-y-1/2 group"
            style={`left:${p.x}%; top:${p.y}%`}
          >
            <span class="block w-3 h-3 rounded-full bg-dragonfire shadow-[0_0_18px_rgba(67,199,199,0.9)] animate-pulseGlow"></span>
            <div class="absolute left-5 top-1/2 -translate-y-1/2 whitespace-nowrap px-2 py-1 rounded border border-storm/40 bg-tempest/80 backdrop-blur-sm">
              <div class="font-display text-[10px] tracking-[0.25em] text-silver">{p.label}</div>
              <div class="font-sans text-[9px] text-ember/80 tracking-widest uppercase">{p.kind}</div>
            </div>
          </div>
        ))}

        <!-- compass rose -->
        <div class="absolute bottom-4 right-4 w-20 h-20 opacity-80">
          <svg viewBox="0 0 100 100">
            <circle cx="50" cy="50" r="44" fill="none" stroke="#D8E0E5" stroke-opacity="0.4" stroke-width="0.8"/>
            <circle cx="50" cy="50" r="36" fill="none" stroke="#43C7C7" stroke-opacity="0.4" stroke-width="0.4" stroke-dasharray="1 3"/>
            <path d="M50 8 L54 50 L50 92 L46 50 Z" fill="#D8E0E5" opacity="0.9"/>
            <path d="M8 50 L50 46 L92 50 L50 54 Z" fill="#43C7C7" opacity="0.85"/>
            <circle cx="50" cy="50" r="2" fill="#B88A3B"/>
            <text x="50" y="6" text-anchor="middle" font-family="Cinzel" font-size="6" fill="#D8E0E5">N</text>
          </svg>
        </div>
      </div>

      <!-- map toolbar -->
      <div class="flex items-center justify-between px-4 py-3 text-xs font-sans">
        <div class="flex items-center gap-4 text-fog/80">
          <span class="flex items-center gap-2"><Icon name="map" size={14} class="text-dragonfire" /> Realm of Vaerithyn</span>
          <span class="hidden md:inline">Scale 1 : 240,000</span>
        </div>
        <div class="flex items-center gap-2 text-fog/70">
          <button class="px-2 py-1 rounded border border-storm/30 hover:border-dragonfire/40 hover:text-dragonfire transition">Eras</button>
          <button class="px-2 py-1 rounded border border-storm/30 hover:border-dragonfire/40 hover:text-dragonfire transition">Factions</button>
          <button class="px-2 py-1 rounded border border-storm/30 hover:border-dragonfire/40 hover:text-dragonfire transition">Lore</button>
        </div>
      </div>
    </div>
  </div>
</section>
