---
import SectionHeader from './SectionHeader.astro';
import Icon from './Icon.astro';

const eras = [
  { era: 'Age of Sundering', year: '−3,400', icon: 'lightning', title: 'The Shattering of the Sky', body: 'Skywyrms fall from a fractured heaven, scattering elemental shards across the continents.' },
  { era: 'Bronze Crowns', year: '−1,200', icon: 'crown', title: 'The First Concord', body: 'Seven kingdoms swear fealty beneath the dragon banners; the Concord of Veylhold is signed.' },
  { era: 'War of Embers', year: '0', icon: 'flame', title: 'House Karnoth Rises', body: 'Fire-blooded dragons descend from the Cinderveil. Cities burn for thirty years.' },
  { era: 'Quiet Centuries', year: '320', icon: 'feather', title: 'The Long Hush', body: 'Magic recedes. Scholars copy what remains. The archives are founded.' },
  { era: 'Tempest Wake', year: '714', icon: 'lightning', title: 'Storms Return to Skyfracture', body: 'The Vorelith line awakens. The age you are writing begins now.' },
];
---
<section id="timelines" class="relative py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <SectionHeader
      eyebrow="The Timeline Engine"
      title="Eras, ruptures, and the threads that bind them."
      description="Pin every coronation, cataclysm, and quiet century on a living chronology — then trace cause to consequence."
    />

    <div class="relative">
      <!-- vertical glowing spine -->
      <div class="absolute left-6 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-dragonfire/0 via-dragonfire/40 to-dragonfire/0"></div>

      <ol class="space-y-10">
        {eras.map((e, i) => {
          const left = i % 2 === 0;
          return (
            <li class="relative md:grid md:grid-cols-2 md:gap-12">
              <!-- node -->
              <span class="absolute left-6 md:left-1/2 -translate-x-1/2 top-3 w-3 h-3 rounded-full bg-dragonfire shadow-[0_0_18px_rgba(67,199,199,0.9)]"></span>

              <div class={`${left ? 'md:col-start-1' : 'md:col-start-2'} pl-14 md:pl-0 ${left ? 'md:pr-12 md:text-right' : 'md:pl-12'}`}>
                <div class={`flex items-center gap-3 ${left ? 'md:justify-end' : ''}`}>
                  <span class="font-display text-[10px] tracking-[0.3em] text-ember/80">{e.era}</span>
                  <span class="font-serif italic text-fog">· Year {e.year}</span>
                </div>

                <div class={`mt-3 card p-6 ${left ? 'md:ml-auto' : ''}`} style="max-width: 28rem">
                  <div class={`flex items-center gap-3 text-dragonfire ${left ? 'md:flex-row-reverse md:text-right' : ''}`}>
                    <Icon name={e.icon as any} size={20} />
                    <h3 class="font-display text-lg tracking-wide text-silver">{e.title}</h3>
                  </div>
                  <p class={`text-fog/80 text-sm mt-3 leading-relaxed ${left ? 'md:text-right' : ''}`}>{e.body}</p>
                </div>
              </div>
            </li>
          );
        })}
      </ol>
    </div>
  </div>
</section>
