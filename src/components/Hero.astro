---
import Sigil from './Sigil.astro';
const base = import.meta.env.BASE_URL;
const appHref = `${base}app/`;
const heroSrc = `${base}hero.png`;
---
<section class="relative overflow-hidden min-h-[100vh] flex items-center">
  <!-- ===== Full-bleed cinematic backdrop ===== -->
  <div aria-hidden="true" class="absolute inset-0 -z-10">
    <!-- The user's painted hero image -->
    <img
      src={heroSrc}
      alt=""
      class="absolute inset-0 w-full h-full object-cover select-none"
      style="object-position: center;"
      fetchpriority="high"
      decoding="async"
    />

    <!-- Atmospheric tonal wash to deepen blacks + bias toward brand palette -->
    <div
      class="absolute inset-0"
      style="background:
        radial-gradient(ellipse at 20% 25%, rgba(67,199,199,0.10) 0%, transparent 55%),
        radial-gradient(ellipse at 80% 75%, rgba(11,30,45,0.55) 0%, transparent 65%),
        linear-gradient(180deg, rgba(8,18,26,0.25) 0%, rgba(5,12,18,0.45) 60%, rgba(2,6,10,0.85) 100%);"
    ></div>

    <!-- Center vignette + readability layer behind text -->
    <div
      class="absolute inset-0"
      style="background:
        radial-gradient(ellipse at 50% 50%, rgba(8,18,26,0.55) 0%, transparent 55%),
        radial-gradient(ellipse at 50% 50%, transparent 60%, rgba(0,0,0,0.55) 100%);"
    ></div>

    <!-- Lightning flash overlay (CSS-animated) -->
    <div class="lightning-flash absolute inset-0 pointer-events-none"></div>

    <!-- Drifting embers -->
    <div class="absolute inset-0 pointer-events-none">
      {Array.from({ length: 18 }).map((_, i) => (
        <span
          class="ember-drift"
          style={`left:${(i * 5.4) % 100}%; top:${50 + ((i * 11) % 40)}%; animation-delay:${(i * 0.9) % 16}s;`}
        ></span>
      ))}
    </div>
  </div>

  <!-- ===== Foreground content ===== -->
  <div class="relative max-w-7xl mx-auto px-6 lg:px-10 py-24 lg:py-32 w-full">
    <div class="text-center max-w-4xl mx-auto">
      <div class="flex items-center justify-center gap-3 mb-7">
        <span class="rule-flourish">Vol. I — The Living Codex</span>
      </div>
      <h1 class="font-display text-5xl md:text-7xl lg:text-[88px] leading-[0.98] tracking-tight text-silver glow-text">
        Build Your World.
        <span class="block text-dragonfire italic font-serif font-medium mt-2">Share Your Legend.</span>
      </h1>
      <p class="mt-8 mx-auto max-w-2xl text-fog/95 text-lg leading-relaxed font-sans"
         style="text-shadow: 0 2px 12px rgba(0,0,0,0.6);">
        Stormforge is a cinematic worldbuilding archive for fantasy creators —
        organize lore, dragons, kingdoms, religions, and timelines inside a single
        immersive codex that feels worthy of the stories it holds.
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a href={appHref} class="btn-primary">Begin Your Chronicle</a>
        <a href="#codex" class="btn-ghost">Tour the Archive</a>
      </div>

      <!-- ornamental compass divider -->
      <div class="mt-14 flex items-center justify-center gap-4 text-ember/80">
        <span class="h-px w-20 bg-gradient-to-r from-transparent via-ember/60 to-transparent"></span>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
          <circle cx="12" cy="12" r="10" />
          <path d="M12 4 L13.5 11 L20 12 L13.5 13 L12 20 L10.5 13 L4 12 L10.5 11 Z" fill="currentColor" opacity="0.85"/>
        </svg>
        <span class="h-px w-20 bg-gradient-to-r from-transparent via-ember/60 to-transparent"></span>
      </div>

      <!-- stat strip beneath flourish -->
      <div class="mt-12 grid grid-cols-2 md:grid-cols-4 gap-6 max-w-3xl mx-auto">
        {[
          { k: '23', l: 'Lore Categories' },
          { k: '∞', l: 'Realms Forged' },
          { k: '7', l: 'Dragon Houses' },
          { k: '1', l: 'Living Codex' },
        ].map((s) => (
          <div class="px-2">
            <div class="font-display text-3xl text-dragonfire" style="text-shadow: 0 0 24px rgba(67,199,199,0.5);">{s.k}</div>
            <div class="font-sans text-[11px] tracking-[0.25em] uppercase text-fog/80 mt-1" style="text-shadow: 0 1px 6px rgba(0,0,0,0.7);">{s.l}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- bottom rune divider -->
  <div class="relative max-w-6xl mx-auto px-6 -mt-2">
    <div class="rune-divider"></div>
  </div>
</section>

<style>
  /* Lightning flash — sudden brightening every few seconds */
  @keyframes lightningFlash {
    0%, 92%, 100% { opacity: 0; }
    93%           { opacity: 0.4; }
    94%           { opacity: 0.05; }
    95%           { opacity: 0.5; }
    96%           { opacity: 0.0; }
    97%           { opacity: 0.18; }
    98%           { opacity: 0.0; }
  }
  .lightning-flash {
    background: radial-gradient(ellipse at 25% 30%, rgba(180, 230, 240, 0.55) 0%, transparent 60%);
    animation: lightningFlash 8.5s ease-in-out infinite;
    mix-blend-mode: screen;
  }

  /* Drifting embers */
  .ember-drift {
    position: absolute;
    width: 2px; height: 2px;
    background: rgba(67,199,199,0.75);
    border-radius: 9999px;
    filter: blur(0.5px);
    animation: emberFloat 22s linear infinite;
    opacity: 0;
  }
  @keyframes emberFloat {
    0%   { transform: translateY(20px); opacity: 0; }
    15%  { opacity: 0.6; }
    85%  { opacity: 0.35; }
    100% { transform: translateY(-280px); opacity: 0; }
  }
</style>
