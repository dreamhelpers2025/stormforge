---
import Sigil from './Sigil.astro';
---
<section class="relative overflow-hidden">
  <!-- storm cloud backdrop -->
  <div aria-hidden="true" class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-storm-veil"></div>
    <!-- clouds -->
    <div class="absolute inset-x-0 top-0 h-[70%] opacity-80">
      <div class="absolute -top-20 -left-20 w-[80%] h-[60%] rounded-full blur-3xl bg-[#0e2030] animate-drift"></div>
      <div class="absolute top-10 -right-32 w-[70%] h-[55%] rounded-full blur-3xl bg-[#102a3a] animate-drift" style="animation-delay:-9s"></div>
      <div class="absolute top-32 left-1/3 w-[60%] h-[40%] rounded-full blur-3xl bg-[#0a1a26] animate-drift" style="animation-delay:-15s"></div>
    </div>
    <!-- jagged lightning bolt SVG -->
    <svg class="absolute left-[18%] top-0 h-[80%] w-32 opacity-30 mix-blend-screen animate-flicker" viewBox="0 0 80 400" preserveAspectRatio="none" aria-hidden="true">
      <path d="M40 0 L30 120 L48 130 L22 250 L46 260 L18 400" fill="none" stroke="#9ee5ec" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" filter="url(#bf)"/>
      <defs>
        <filter id="bf" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="3"/>
        </filter>
      </defs>
    </svg>
    <!-- mountains/silhouette ridge -->
    <svg class="absolute bottom-0 left-0 w-full h-[40%]" viewBox="0 0 1440 400" preserveAspectRatio="none" aria-hidden="true">
      <defs>
        <linearGradient id="ridge" x1="0" x2="0" y1="0" y2="1">
          <stop offset="0%" stop-color="#0B1E2D" stop-opacity="0"/>
          <stop offset="100%" stop-color="#050d14" stop-opacity="1"/>
        </linearGradient>
      </defs>
      <path d="M0 280 L80 230 L160 260 L240 200 L320 240 L400 180 L480 230 L560 170 L640 220 L720 160 L800 210 L880 150 L960 200 L1040 140 L1120 200 L1200 160 L1280 220 L1360 180 L1440 240 L1440 400 L0 400 Z"
            fill="url(#ridge)" opacity="0.9"/>
      <path d="M0 320 L120 290 L240 320 L360 280 L480 310 L600 270 L720 310 L840 280 L960 320 L1080 290 L1200 320 L1320 290 L1440 320 L1440 400 L0 400 Z"
            fill="#050d14"/>
    </svg>
    <!-- dragon silhouette in clouds -->
    <svg class="absolute right-[-6%] bottom-[12%] w-[55%] max-w-[820px] opacity-90" viewBox="0 0 600 360" aria-hidden="true">
      <defs>
        <linearGradient id="dragonFill" x1="0" x2="1" y1="0" y2="1">
          <stop offset="0%" stop-color="#0a1a26"/>
          <stop offset="60%" stop-color="#06121b"/>
          <stop offset="100%" stop-color="#020608"/>
        </linearGradient>
        <linearGradient id="dragonEdge" x1="0" x2="1" y1="0" y2="0">
          <stop offset="0%" stop-color="#43C7C7" stop-opacity="0.7"/>
          <stop offset="100%" stop-color="#1E7C86" stop-opacity="0.0"/>
        </linearGradient>
      </defs>
      <!-- wing back -->
      <path d="M120 60 C 60 140, 60 240, 180 280 L 240 220 C 200 200, 170 160, 170 120 Z" fill="url(#dragonFill)"/>
      <!-- body -->
      <path d="M180 280 C 260 320, 360 310, 430 250 C 500 200, 540 140, 560 60 L 510 70 C 470 130, 420 160, 360 170 C 300 180, 240 200, 200 240 Z" fill="url(#dragonFill)"/>
      <!-- head/horns -->
      <path d="M560 60 L 580 30 L 555 50 L 575 10 L 545 45 L 565 8 L 540 42 L 530 58 L 560 60 Z" fill="url(#dragonFill)"/>
      <!-- eye glow -->
      <circle cx="535" cy="58" r="2.5" fill="#43C7C7"/>
      <circle cx="535" cy="58" r="5" fill="#43C7C7" opacity="0.25"/>
      <!-- wing front w/ edge glow -->
      <path d="M260 130 C 300 80, 380 60, 470 60 L 460 100 C 400 110, 340 140, 300 180 Z" fill="url(#dragonFill)"/>
      <path d="M260 130 C 300 80, 380 60, 470 60" fill="none" stroke="url(#dragonEdge)" stroke-width="1.5"/>
      <!-- tail -->
      <path d="M180 280 C 130 300, 80 300, 40 280 L 70 270 C 110 280, 150 280, 180 270 Z" fill="url(#dragonFill)"/>
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-10 pt-20 pb-32 lg:pt-28 lg:pb-44 relative">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-6">
        <span class="rule-flourish">Vol. I — The Living Codex</span>
      </div>
      <h1 class="font-display text-5xl md:text-6xl lg:text-7xl leading-[1.05] tracking-tight text-silver">
        Forge Kingdoms.
        <span class="block text-dragonfire glow-text italic font-serif">Archive Legends.</span>
      </h1>
      <p class="mt-8 max-w-xl text-fog/90 text-lg leading-relaxed font-sans">
        Stormforge is a cinematic worldbuilding archive for fantasy creators —
        organize lore, dragons, kingdoms, religions, and timelines inside a
        single immersive codex that feels worthy of the stories it holds.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a href="#enter" class="btn-primary">Begin Your Chronicle</a>
        <a href="#codex" class="btn-ghost">Tour the Archive</a>
      </div>

      <!-- stat strip -->
      <div class="mt-14 grid grid-cols-2 md:grid-cols-4 gap-6 max-w-2xl">
        {[
          { k: '14', l: 'Lore Categories' },
          { k: '∞', l: 'Realms Forged' },
          { k: '7', l: 'Elemental Dragon Houses' },
          { k: '1', l: 'Archive That Endures' },
        ].map((s) => (
          <div class="border-l border-storm/40 pl-4">
            <div class="font-display text-3xl text-dragonfire">{s.k}</div>
            <div class="font-sans text-[11px] tracking-[0.25em] uppercase text-fog/70 mt-1">{s.l}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- floating sigil -->
    <div class="hidden lg:block absolute right-10 top-24 animate-pulseGlow rounded-full">
      <Sigil size={180} class="text-dragonfire opacity-90" />
    </div>
  </div>

  <!-- bottom rune divider -->
  <div class="max-w-6xl mx-auto px-6">
    <div class="rune-divider"></div>
  </div>
</section>
