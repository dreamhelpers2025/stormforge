---
interface Props {
  name:
    | 'codex'
    | 'dragon'
    | 'map'
    | 'scroll'
    | 'shield'
    | 'compass'
    | 'crown'
    | 'rune'
    | 'flame'
    | 'feather'
    | 'lightning'
    | 'claw';
  size?: number;
  class?: string;
}
const { name, size = 28, class: className = '' } = Astro.props;
const stroke = 'currentColor';
---
<svg
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  stroke={stroke}
  stroke-width="1.4"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  {name === 'codex' && (
    <>
      <path d="M5 6c4-1 7-1 11 1 4-2 7-2 11-1v20c-4-1-7-1-11 1-4-2-7-2-11-1V6z"/>
      <path d="M16 7v21"/>
      <path d="M9 12h4M9 16h4M19 12h4M19 16h4"/>
    </>
  )}
  {name === 'dragon' && (
    <>
      <path d="M6 20c2-6 7-9 13-9l5-3-2 5c2 1 3 3 3 5"/>
      <path d="M19 11c2 0 3 2 3 4"/>
      <circle cx="20" cy="13" r="0.8" fill="currentColor"/>
      <path d="M10 21l-3 5 5-2 3 2 3-2 4 3-1-5"/>
    </>
  )}
  {name === 'map' && (
    <>
      <path d="M4 8l7-2 10 2 7-2v18l-7 2-10-2-7 2V8z"/>
      <path d="M11 6v18M21 8v18"/>
      <circle cx="16" cy="15" r="1.2"/>
    </>
  )}
  {name === 'scroll' && (
    <>
      <path d="M7 6h14a2 2 0 012 2v3H9V8a2 2 0 00-2-2z"/>
      <path d="M7 6a2 2 0 00-2 2v16a2 2 0 002 2h14a2 2 0 002-2V11"/>
      <path d="M12 16h7M12 20h7"/>
    </>
  )}
  {name === 'shield' && (
    <>
      <path d="M16 4l10 3v8c0 7-5 11-10 13C11 26 6 22 6 15V7l10-3z"/>
      <path d="M12 15l3 3 5-6"/>
    </>
  )}
  {name === 'compass' && (
    <>
      <circle cx="16" cy="16" r="11"/>
      <path d="M16 7l3 8-3 10-3-10 3-8z"/>
      <circle cx="16" cy="16" r="1.2" fill="currentColor"/>
    </>
  )}
  {name === 'crown' && (
    <>
      <path d="M5 12l4 8h14l4-8-6 4-5-8-5 8-6-4z"/>
      <path d="M9 23h14"/>
    </>
  )}
  {name === 'rune' && (
    <>
      <circle cx="16" cy="16" r="11"/>
      <path d="M11 9v14M11 9l5 5 5-5M11 16l5 5 5-5"/>
    </>
  )}
  {name === 'flame' && (
    <>
      <path d="M16 4c2 6 7 8 7 14a7 7 0 11-14 0c0-4 3-5 4-9 2 2 3 5 3 8"/>
    </>
  )}
  {name === 'feather' && (
    <>
      <path d="M22 4c-9 1-15 7-15 16v4l4-4c9 0 15-6 16-15z"/>
      <path d="M7 24l14-14"/>
    </>
  )}
  {name === 'lightning' && (
    <>
      <path d="M17 3l-9 14h6l-2 12 10-15h-6l1-11z"/>
    </>
  )}
  {name === 'claw' && (
    <>
      <path d="M6 6c4 4 4 10 0 14"/>
      <path d="M12 6c5 5 5 12 0 16"/>
      <path d="M18 6c6 6 6 14 0 20"/>
    </>
  )}
</svg>
