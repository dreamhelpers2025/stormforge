---
import SectionHeader from './SectionHeader.astro';
import Icon from './Icon.astro';

const nodes = [
  { id: 'a', label: 'House Vorelith',  x: 50, y: 18, color: '#43C7C7' },
  { id: 'b', label: 'Concord of Veylhold', x: 18, y: 48, color: '#D8E0E5' },
  { id: 'c', label: 'Order of the Quill', x: 82, y: 48, color: '#B88A3B' },
  { id: 'd', label: 'House Karnoth', x: 30, y: 82, color: '#B88A3B' },
  { id: 'e', label: 'House Maelyr',   x: 70, y: 82, color: '#1E7C86' },
];
const edges = [
  ['a','b','ally'], ['a','c','sworn'], ['a','d','feud'],
  ['b','d','treaty'], ['c','e','pact'], ['d','e','rival'],
] as const;
const pos = Object.fromEntries(nodes.map(n => [n.id, { x: n.x, y: n.y }]));
const edgeColor: Record<string, string> = {
  ally:   '#43C7C7',
  sworn:  '#D8E0E5',
  feud:   '#B0413E',
  treaty: '#B88A3B',
  pact:   '#43C7C7',
  rival:  '#7a2b2b',
};
---
<section id="factions" class="relative py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <SectionHeader
      eyebrow="Character & Faction Network"
      title="The web beneath every kingdom."
      description="Map allegiances, betrayals, marriages, and oaths. Every relationship is a thread — pull one and watch the world react."
    />

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
      <!-- graph -->
      <div class="card lg:col-span-3 p-6">
        <div class="flex items-center justify-between mb-4">
          <div class="font-display text-[11px] tracking-[0.3em] text-ember/80">RELATIONSHIP GRAPH</div>
          <div class="text-xs text-fog/70">{nodes.length} houses · {edges.length} bonds</div>
        </div>
        <div class="relative aspect-square w-full max-w-[560px] mx-auto">
          <svg viewBox="0 0 100 100" class="absolute inset-0 w-full h-full">
            <!-- edges -->
            {edges.map(([a, b, kind]) => (
              <line
                x1={pos[a].x} y1={pos[a].y}
                x2={pos[b].x} y2={pos[b].y}
                stroke={edgeColor[kind]}
                stroke-opacity="0.55"
                stroke-width="0.4"
                stroke-dasharray={kind === 'feud' || kind === 'rival' ? '1 1.2' : '0'}
              />
            ))}
            <!-- nodes -->
            {nodes.map((n) => (
              <g>
                <circle cx={n.x} cy={n.y} r="4.5" fill={n.color} fill-opacity="0.2" />
                <circle cx={n.x} cy={n.y} r="2.2" fill={n.color} />
                <text x={n.x} y={n.y - 5.5} text-anchor="middle" font-family="Cinzel" font-size="2.4" fill="#D8E0E5">{n.label}</text>
              </g>
            ))}
          </svg>
        </div>

        <!-- legend -->
        <div class="mt-4 flex flex-wrap gap-x-6 gap-y-2 text-[11px] font-sans text-fog/80">
          {[
            ['Ally', '#43C7C7'],
            ['Sworn', '#D8E0E5'],
            ['Treaty', '#B88A3B'],
            ['Feud', '#B0413E'],
          ].map(([l, c]) => (
            <span class="flex items-center gap-2">
              <span class="w-3 h-px" style={`background:${c}`}></span>
              {l}
            </span>
          ))}
        </div>
      </div>

      <!-- character roster -->
      <div class="lg:col-span-2 space-y-4">
        {[
          { name: 'Aerith Vorelith', role: 'Storm-Queen', sigil: 'crown' },
          { name: 'Kael Karnoth', role: 'Drakelord of Cinders', sigil: 'flame' },
          { name: 'Maester Ory',  role: 'Keeper of the Archive', sigil: 'feather' },
          { name: 'The Whisper of Maelyr', role: 'Speaker of Tides', sigil: 'compass' },
        ].map((c) => (
          <article class="card card-glow p-5 flex items-center gap-4">
            <div class="w-12 h-12 rounded-full border border-dragonfire/30 bg-tempest/60 flex items-center justify-center text-dragonfire shrink-0">
              <Icon name={c.sigil as any} size={20} />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-display tracking-wide text-silver text-base truncate">{c.name}</h3>
              <p class="text-xs font-serif italic text-fog/80 truncate">{c.role}</p>
            </div>
            <span class="font-display text-[10px] tracking-[0.3em] text-ember/80">VIEW</span>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
