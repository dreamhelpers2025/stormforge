---
import '../styles/global.css';
import '../app/styles/app.css';
import App from '../app/App.tsx';
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Stormforge Archive — your worldbuilding workspace." />
    <meta name="theme-color" content="#0B1E2D" />
    <title>Stormforge — Archive</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500;600&display=swap"
    />
    <script is:inline define:vars={{ base }}>
      // Apply saved theme ASAP to avoid flash. Default = dark.
      (function () {
        try {
          const t = localStorage.getItem('stormforge.theme') || 'dark';
          document.documentElement.classList.toggle('theme-light', t === 'light');
          document.documentElement.classList.toggle('theme-dark', t !== 'light');
        } catch (e) {
          document.documentElement.classList.add('theme-dark');
        }
        window.__STORMFORGE_BASE__ = base;
      })();
    </script>
  </head>
  <body class="app-body min-h-screen overflow-hidden">
    <App client:only="react" />
  </body>
</html>
