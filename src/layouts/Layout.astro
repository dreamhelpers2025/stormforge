---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Stormforge Archive — Forge Kingdoms. Archive Legends.',
  description = 'A premium worldbuilding archive for fantasy creators. Organize lore, dragons, kingdoms, timelines, and magic systems inside a cinematic codex.',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0B1E2D" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500;600&display=swap"
    />
  </head>
  <body class="min-h-screen overflow-x-hidden">
    <!-- atmospheric particles layer -->
    <div aria-hidden="true" class="fixed inset-0 pointer-events-none z-0">
      <div class="lightning"></div>
      <div class="absolute inset-0 opacity-[0.35] bg-scale-grid mix-blend-screen"></div>
      <div class="absolute inset-0">
        {Array.from({ length: 14 }).map((_, i) => (
          <span
            class="particle"
            style={`left:${(i * 7.3) % 100}%; top:${60 + ((i * 13) % 35)}%; animation-delay:${(i * 1.4) % 18}s;`}
          ></span>
        ))}
      </div>
    </div>

    <div class="relative z-10">
      <slot />
    </div>
  </body>
</html>
